# OSCAR MCP-server credentials for local development with Claude Code.
#
# Copy to ~/.config/oscar.env (or wherever your shell loads from) and fill
# in real values. Claude Code reads .mcp.json from the repo root and
# substitutes ${VAR} entries from the surrounding environment.
#
# Treat the contents as secret — these tokens grant read access to OSCAR's
# audit tables (including PII in debug-mode), platform operations, and HA.
# Never check this file in with real values; .env.example is the template.

# Postgres connection string used by the oscar-postgres MCP server.
# Best practice: create a read-only role in Postgres for Claude/MCP access.
#
#     CREATE ROLE claude_ro LOGIN PASSWORD '<password>';
#     GRANT CONNECT ON DATABASE oscar TO claude_ro;
#     GRANT USAGE ON SCHEMA public TO claude_ro;
#     GRANT SELECT ON ALL TABLES IN SCHEMA public TO claude_ro;
#     ALTER DEFAULT PRIVILEGES IN SCHEMA public GRANT SELECT ON TABLES TO claude_ro;
#
# Then use the claude_ro credentials here, not the main `oscar` superuser DSN.
OSCAR_POSTGRES_DSN=postgresql://claude_ro:CHANGEME@oscar.your-host.local:5432/oscar

# ServiceBay MCP endpoint and bearer (mint via Settings → Integrations → MCP).
# Read+lifecycle scope is enough for diagnostics; don't mint mutate/destroy unless
# you really need it.
OSCAR_SERVICEBAY_MCP_URL=https://servicebay.your-host.local/mcp
OSCAR_SERVICEBAY_MCP_TOKEN=

# Home Assistant MCP endpoint (HA Core integration `mcp_server`, from HA 2025.x).
# Long-Lived Access Token from HA Profile → Security.
OSCAR_HA_MCP_URL=https://ha.your-host.local/mcp_server/sse
OSCAR_HA_MCP_TOKEN=
